{
  "openapi": "3.0.0",
  "info": {
    "title": "Sales System API",
    "description": "API para Sistema de Gestao de Vendas Multi-Tenant",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local Server"
    }
  ],
  "security": [
    {
      "sanctum": []
    }
  ],
  "components": {
    "securitySchemes": {
      "sanctum": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Enter token in format (Bearer <token>)"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register new user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenant_id", "name", "email", "password"],
                "properties": {
                  "tenant_id": {"type": "integer"},
                  "name": {"type": "string"},
                  "email": {"type": "string"},
                  "password": {"type": "string"},
                  "password_confirmation": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "User registered"}
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {"type": "string"},
                  "password": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Login successful"}
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Logout user",
        "tags": ["Authentication"],
        "security": [{"sanctum": []}],
        "responses": {
          "200": {"description": "Logout successful"}
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Get current user",
        "tags": ["Authentication"],
        "security": [{"sanctum": []}],
        "responses": {
          "200": {"description": "Current user data"}
        }
      }
    },
    "/api/tenant": {
      "get": {
        "summary": "List all tenants",
        "tags": ["Tenants"],
        "security": [{"sanctum": []}],
        "parameters": [
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "is_active", "in": "query", "schema": {"type": "boolean"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "List of tenants"}
        }
      },
      "post": {
        "summary": "Create new tenant",
        "tags": ["Tenants"],
        "security": [{"sanctum": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "slug", "email"],
                "properties": {
                  "name": {"type": "string"},
                  "slug": {"type": "string"},
                  "email": {"type": "string"},
                  "cnpj": {"type": "string"},
                  "phone": {"type": "string"},
                  "is_active": {"type": "boolean"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Tenant created"}
        }
      }
    },
    "/api/tenant/{tenant}": {
      "get": {
        "summary": "Get tenant by ID",
        "tags": ["Tenants"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "tenant", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Tenant data"}}
      },
      "put": {
        "summary": "Update tenant",
        "tags": ["Tenants"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "tenant", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "Tenant updated"}}
      },
      "delete": {
        "summary": "Delete tenant",
        "tags": ["Tenants"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "tenant", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Tenant deleted"}}
      }
    },
    "/api/product": {
      "get": {
        "summary": "List all products",
        "tags": ["Products"],
        "security": [{"sanctum": []}],
        "parameters": [
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "is_active", "in": "query", "schema": {"type": "boolean"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "List of products"}}
      },
      "post": {
        "summary": "Create new product",
        "tags": ["Products"],
        "security": [{"sanctum": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenant_id", "name", "price", "stock"],
                "properties": {
                  "tenant_id": {"type": "integer"},
                  "name": {"type": "string"},
                  "sku": {"type": "string"},
                  "description": {"type": "string"},
                  "price": {"type": "number"},
                  "cost": {"type": "number"},
                  "stock": {"type": "integer"},
                  "min_stock": {"type": "integer"},
                  "is_active": {"type": "boolean"}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Product created"}}
      }
    },
    "/api/product/{product}": {
      "get": {
        "summary": "Get product by ID",
        "tags": ["Products"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "product", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Product data"}}
      },
      "put": {
        "summary": "Update product",
        "tags": ["Products"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "product", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "Product updated"}}
      },
      "delete": {
        "summary": "Delete product",
        "tags": ["Products"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "product", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Product deleted"}}
      }
    },
    "/api/customer": {
      "get": {
        "summary": "List all customers",
        "tags": ["Customers"],
        "security": [{"sanctum": []}],
        "parameters": [
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "is_active", "in": "query", "schema": {"type": "boolean"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "List of customers"}}
      },
      "post": {
        "summary": "Create new customer",
        "tags": ["Customers"],
        "security": [{"sanctum": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenant_id", "name", "email"],
                "properties": {
                  "tenant_id": {"type": "integer"},
                  "name": {"type": "string"},
                  "email": {"type": "string"},
                  "cpf_cnpj": {"type": "string"},
                  "phone": {"type": "string"},
                  "address": {"type": "string"},
                  "is_active": {"type": "boolean"}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Customer created"}}
      }
    },
    "/api/customer/{customer}": {
      "get": {
        "summary": "Get customer by ID",
        "tags": ["Customers"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "customer", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Customer data"}}
      },
      "put": {
        "summary": "Update customer",
        "tags": ["Customers"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "customer", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "Customer updated"}}
      },
      "delete": {
        "summary": "Delete customer",
        "tags": ["Customers"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "customer", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Customer deleted"}}
      }
    },
    "/api/sale": {
      "get": {
        "summary": "List all sales",
        "tags": ["Sales"],
        "security": [{"sanctum": []}],
        "parameters": [
          {"name": "status", "in": "query", "schema": {"type": "string"}},
          {"name": "customer_id", "in": "query", "schema": {"type": "integer"}},
          {"name": "date_from", "in": "query", "schema": {"type": "string"}},
          {"name": "date_to", "in": "query", "schema": {"type": "string"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "List of sales"}}
      },
      "post": {
        "summary": "Create new sale",
        "tags": ["Sales"],
        "security": [{"sanctum": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customer_id", "items"],
                "properties": {
                  "customer_id": {"type": "integer"},
                  "discount": {"type": "number"},
                  "status": {"type": "string"},
                  "payment_method": {"type": "string"},
                  "notes": {"type": "string"},
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "product_id": {"type": "integer"},
                        "quantity": {"type": "integer"}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "Sale created"}}
      }
    },
    "/api/sale/{sale}": {
      "get": {
        "summary": "Get sale by ID",
        "tags": ["Sales"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "sale", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Sale data"}}
      },
      "delete": {
        "summary": "Cancel sale",
        "tags": ["Sales"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "sale", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Sale cancelled"}}
      }
    },
    "/api/sale/report": {
      "get": {
        "summary": "Generate sales report",
        "tags": ["Sales"],
        "security": [{"sanctum": []}],
        "parameters": [
          {"name": "status", "in": "query", "schema": {"type": "string"}},
          {"name": "date_from", "in": "query", "schema": {"type": "string"}},
          {"name": "date_to", "in": "query", "schema": {"type": "string"}},
          {"name": "customer_id", "in": "query", "schema": {"type": "integer"}},
          {"name": "cached", "in": "query", "schema": {"type": "boolean"}},
          {"name": "send_email", "in": "query", "schema": {"type": "boolean"}},
          {"name": "email", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "Sales report generated"}}
      }
    },
    "/api/user": {
      "get": {
        "summary": "List all users",
        "tags": ["Users"],
        "security": [{"sanctum": []}],
        "parameters": [
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "is_active", "in": "query", "schema": {"type": "boolean"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "List of users"}}
      },
      "post": {
        "summary": "Create new user",
        "tags": ["Users"],
        "security": [{"sanctum": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenant_id", "name", "email", "password"],
                "properties": {
                  "tenant_id": {"type": "integer"},
                  "name": {"type": "string"},
                  "email": {"type": "string"},
                  "password": {"type": "string"},
                  "password_confirmation": {"type": "string"},
                  "role": {"type": "string"},
                  "is_active": {"type": "boolean"}
                }
              }
            }
          }
        },
        "responses": {"201": {"description": "User created"}}
      }
    },
    "/api/user/{user}": {
      "get": {
        "summary": "Get user by ID",
        "tags": ["Users"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "user", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "User data"}}
      },
      "put": {
        "summary": "Update user",
        "tags": ["Users"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "user", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "User updated"}}
      },
      "delete": {
        "summary": "Delete user",
        "tags": ["Users"],
        "security": [{"sanctum": []}],
        "parameters": [{"name": "user", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "User deleted"}}
      }
    },
    "/api/dashboard/stats": {
      "get": {
        "summary": "Get dashboard statistics",
        "tags": ["Dashboard"],
        "security": [{"sanctum": []}],
        "responses": {
          "200": {
            "description": "Dashboard statistics retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_sales": {"type": "number", "example": 15000.00},
                    "total_customers": {"type": "integer", "example": 25},
                    "total_products": {"type": "integer", "example": 100},
                    "total_users": {"type": "integer", "example": 5},
                    "sales_today": {"type": "number", "example": 1200.00},
                    "sales_this_month": {"type": "number", "example": 8500.00}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
